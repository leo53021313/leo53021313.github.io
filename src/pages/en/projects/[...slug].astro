---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CaseStudy from '../../../components/CaseStudy.astro';
import { getLocalizedProjects } from '../../../i18n/utils';

export async function getStaticPaths() {
  const items = await getLocalizedProjects('en');
  return items.map(({ entry, slug }, i) => ({
    params: { slug },
    props: { entry, prev: items[i - 1]?.entry, next: items[i + 1]?.entry },
  }));
}
const { entry, prev, next } = Astro.props;
const d = entry.data;
---
<BaseLayout title={`${d.title} · Leo`} description={d.oneLiner}>
  <CaseStudy entry={entry} prev={prev} next={next} />
</BaseLayout>
