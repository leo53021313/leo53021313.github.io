---
// src/layouts/BaseLayout.astro
// Inter + JetBrains Mono are now served via Astro's native font API (see astro.config.mjs
// + the <Font> components in BaseHead). Noto Sans TC stays a fontsource import: its CJK
// unicode-range slicing is what keeps Chinese pages light, and the font provider can't
// subset CJK safely.
import '@fontsource-variable/noto-sans-tc';
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
interface Props { title: string; description: string; image?: string; }
const { title, description, image } = Astro.props;
const htmlLang = getLangFromUrl(Astro.url) === 'en' ? 'en' : 'zh-Hant-TW';
const t = useTranslations(getLangFromUrl(Astro.url));
---
<!doctype html>
<html lang={htmlLang}>
  <head><BaseHead title={title} description={description} image={image} /></head>
  <body>
    <a href="#main" class="skip-link">{t('a11y.skip')}</a>
    <Header />
    <main id="main" class="container"><slot /></main>
    <Footer />
  </body>
</html>
